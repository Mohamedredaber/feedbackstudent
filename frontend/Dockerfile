# 1. استخدام نسخة Node حديثة وخفيفة لتقليل حجم الصورة
FROM node:22-alpine

# 2. تحديد مسار العمل داخل الحاوية
WORKDIR /app

# 3. نسخ ملفات التعريف أولاً لضمان سرعة البناء (Caching)
COPY package*.json ./

# 4. تثبيت المكتبات
RUN npm install

# 5. نسخ باقي ملفات المشروع
COPY . .

# 6. فتح البورت 3000 (البورت الموحد للـ Frontend)
EXPOSE 3000

# 7. تشغيل السيرفر مع السماح بالاتصال الخارجي (--host)
CMD ["npm", "run", "dev", "--", "--port", "3000", "--host", "0.0.0.0"]